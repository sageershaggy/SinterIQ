# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Gemini API key used by lead research, contact enrichment, and AI qualification routes.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Optional generic OpenAI-compatible fallback used when settings are not stored in the app UI.
# Examples:
# - OpenRouter: LLM_PROVIDER_NAME="OpenRouter", LLM_BASE_URL="https://openrouter.ai/api/v1", LLM_MODEL="deepseek/deepseek-v4-flash"
# - DeepSeek: LLM_PROVIDER_NAME="DeepSeek", LLM_BASE_URL="https://api.deepseek.com", LLM_MODEL="deepseek-v4-flash"
# - Kimi: LLM_PROVIDER_NAME="Kimi", LLM_BASE_URL="https://api.moonshot.ai/v1", LLM_MODEL="kimi-k2.6"
# - GLM/Z.AI: LLM_PROVIDER_NAME="Z.AI", LLM_BASE_URL="https://api.z.ai/api/paas/v4", LLM_MODEL="glm-5.1"
LLM_PROVIDER_NAME="OpenRouter"
LLM_API_KEY="YOUR_LLM_API_KEY"
LLM_MODEL="deepseek/deepseek-v4-flash"
LLM_BASE_URL="https://openrouter.ai/api/v1"
